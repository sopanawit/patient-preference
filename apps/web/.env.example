# ============================================================================
# Environment สำหรับ frontend (Vite) — ค่าเหล่านี้เปิดเผยฝั่ง client ได้
# คัดลอกเป็น apps/web/.env แล้วใส่ค่าจริง
#
# ⚠️ ใส่ได้เฉพาะ anon key เท่านั้น — ห้ามใส่ service_role key หรือ API key ของโมเดล
#    (secret ของโมเดลอยู่ใน Supabase Edge Function เท่านั้น — ดู supabase/.env.example)
# ============================================================================

VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
